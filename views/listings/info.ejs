<% layout("../layouts/boilerplate") -%>
<body>
    <!-- --------show section-------------- -->
    <div class="row">
        <div class="col-8 offset-2">
            <h1><b><%=data.title %></b></h1>
        </div>
    </div>
    <div class="row">
        
            <div class="col-6 offset-2 card listing-card" >
                <img src=<%= data.img.url %> class="card-img-top" alt="">
                <div class="card-body info-body">
                    <p class="card-text"><i>Owned by <%= data.owner.username %></i></p>
                    <p class="card-text"><%= data.description %></p>
                    <p class="card-text">&#x20B9;<%= data.price.toLocaleString("en-in") %></p>
                    <p class="card-text"><%= data.location %></p><%= data.location %>
                    <p class="card-text"><%= data.country %></p>
                  
                   <% if(currUser && currUser._id.equals(data.owner._id)) {%>
                    <div class="info-btn">
                    <button class="btn btn-danger"><a href="/listings/<%= data._id %>/edit" class="info-link">edit</a></button>
                     <form method="post" action="/listings/<%=data._id %>?_method=DELETE">    
                            <button class="btn btn-dark">delete this listing</button>
                    </form>
                    </div>
                    <% } %>
                </div>
                    </div>
              
        </div>
    </div>
    <hr>
    <!-- //--------------review section-------------------- -->
    <div class="row mb-5">
        <% if(currUser){ %>
        <form class="col-6 offset-2 needs-validation" method="post" 
        action="/listings/<%= data._id %>/reviews" novalidate >
            <div class="mb-1">
                <!-- <label for="rating" class="form-label">rating</label> -->
                <fieldset class="starability-fade">
                    <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="rating" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="rating" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="rating" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="rating" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="rating" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
            </div>
            <div class="mb-3">
                <label for="comment" class="form-label">comment:</label>
                <textarea class="form-control" rows="5" 
                    cols="30"
                    name="comment" required></textarea>
                <div class="invalid-feedback">
                    add a review first;
                </div>
            </div>
            <button class="btn btn-outline-primary mb-3">submit</button>
           
        </form>
        <hr class="col-6 offset-2">
        <% } %>
         
          <div class=" row col-6 offset-2">
            <h3>All Reviews</h3>
            <!-- <div class="row mt-3"> -->
                <% for(review of data.review){ %>
                    <div class="card col-5 ms-1 mb-3">
                        <div class="card-body">      
                            <h5 class="card-title">@<%=review.author.username %></h5>
                            <p class="starability-result card-text" data-rating="<%= review.rating %>">
                               3 stars
                            </p>
                            <p class="card-text"><%= review.comment %></p>
                           
                        </div>
                        <% if(currUser && currUser._id.equals(review.author._id)) {%>
                        <form class="mb-3" method="post" action="/listings/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE" >
                            <button class="btn btn-outline-dark">Delete</button>
                        </form>
                        <% } %>
                    </div>
                    <% } %>
            <!-- </div> -->
            </div>
    </div>
    <div>
    
    
</body>
